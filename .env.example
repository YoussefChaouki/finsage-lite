# ==============================================================================
# FinSage-Lite — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Project
# OPTIONAL — display name used in API responses and logs
# ------------------------------------------------------------------------------
PROJECT_NAME="FinSage-Lite"

# ------------------------------------------------------------------------------
# Database (PostgreSQL + pgvector) — all five are REQUIRED
# SECURITY: change POSTGRES_PASSWORD before deploying to production
# ------------------------------------------------------------------------------
POSTGRES_USER=finsage
POSTGRES_PASSWORD=finsage_password
POSTGRES_DB=finsage_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# SEC EDGAR API — REQUIRED
# The SEC mandates a descriptive User-Agent that includes a contact email.
# Format: "AppName contact@example.com"
# Requests without a valid email may be rate-limited or blocked by EDGAR.
# ------------------------------------------------------------------------------
EDGAR_USER_AGENT="FinSage-Lite your-email@example.com"

# ------------------------------------------------------------------------------
# Ollama (local LLM) — OPTIONAL
# Used for HyDE query expansion and answer generation.
# The system runs in retrieval-only mode if Ollama is unavailable.
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ------------------------------------------------------------------------------
# Embedding Model — OPTIONAL (changing requires full re-ingestion)
# ------------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=64

# ------------------------------------------------------------------------------
# Chunking — OPTIONAL (defaults tuned for MiniLM's 256-token window)
# ------------------------------------------------------------------------------
CHUNK_SIZE=220
CHUNK_OVERLAP=50

# ------------------------------------------------------------------------------
# Retrieval / Search — OPTIONAL
# ------------------------------------------------------------------------------
BM25_K1=1.5
BM25_B=0.75
RRF_K=60
DEFAULT_TOP_K=5

# ------------------------------------------------------------------------------
# CORS — OPTIONAL
# SECURITY: restrict to your actual domain(s) in production.
# Example: CORS_ORIGINS=["https://app.yourdomain.com"]
# ------------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ------------------------------------------------------------------------------
# Logging — OPTIONAL (DEBUG | INFO | WARNING | ERROR)
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
